---
import { useTranslations, languages, type Lang } from '../i18n/ui';
import { localizedPath, switchLocaleHref } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const nav = [
  { href: localizedPath(lang, '/products/hearth-di16g'), label: t('nav.hearth') },
  { href: localizedPath(lang, '/products/ember-di16x'), label: t('nav.ember') },
  { href: localizedPath(lang, '/docs/getting-started'), label: t('nav.gettingStarted') },
];

const pathname = Astro.url.pathname;
const localeLinks = (Object.keys(languages) as Lang[]).map((code) => ({
  code,
  label: languages[code],
  href: switchLocaleHref(pathname, code),
  active: code === lang,
}));
---
<header class="site-header">
  <div class="wrap">
    <a class="brand" href={localizedPath(lang, '/')}>
      <svg class="mark" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <linearGradient id="hf" x1="16" y1="2" x2="16" y2="30" gradientUnits="userSpaceOnUse">
          <stop stop-color="#ff8c5a"/><stop offset="1" stop-color="#ff6a2b"/>
        </linearGradient>
        <path fill="url(#hf)" d="M16 2c1.6 5-3.2 7-3.2 11.5 0 2 1 3.4 2.2 4.3-.5-2.1.3-4 1.7-5.2.2 3 2.4 4 3.8 6.2 1.7 2.7.6 6.6-2.3 8.2 4.6-.5 8.1-4 8.1-8.8C26 11.4 19.2 9 16 2Z"/>
      </svg>
      OSELIA
    </a>
    <nav class="nav">
      {nav.map((n) => <a class="hide-sm" href={n.href}>{n.label}</a>)}
      <div class="lang-switch" role="group" aria-label={t('lang.label')}>
        {localeLinks.map((l) => (
          <a
            href={l.href}
            class={l.active ? 'active' : ''}
            aria-current={l.active ? 'true' : undefined}
            lang={l.code}
          >{l.code.toUpperCase()}</a>
        ))}
      </div>
      <a class="btn btn-ghost hide-sm" href="https://github.com/vmyronovych/oselia" target="_blank" rel="noopener">{t('nav.github')}</a>
    </nav>
  </div>
</header>
