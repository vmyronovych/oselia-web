---
import { useTranslations, type Lang } from '../i18n/ui';
import { localizedPath } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
const adminHref = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/admin/`;
---
<footer class="site-footer">
  <div class="wrap">
    <div>© {year} {t('footer.tagline')}</div>
    <div style="display:flex; gap:1.2rem; flex-wrap:wrap;">
      <a href={localizedPath(lang, '/docs/getting-started')}>{t('footer.docs')}</a>
      <a href="https://github.com/vmyronovych/oselia-hearth-di16g-firmware" target="_blank" rel="noopener">{t('footer.firmware')}</a>
      <a href="https://github.com/vmyronovych/oselia-hearth-di16g-ha" target="_blank" rel="noopener">{t('footer.ha')}</a>
      <a href={adminHref}>{t('footer.cms')}</a>
    </div>
  </div>
</footer>
