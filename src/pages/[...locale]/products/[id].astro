---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, type Lang } from '../../../i18n/ui';
import { entryLang, entrySlug, localePrefix, localizedPath } from '../../../i18n/utils';

export async function getStaticPaths() {
  const products = await getCollection('products', ({ data }) => !data.draft);
  return products.map((product) => {
    const lang = entryLang(product.id);
    return {
      params: { locale: localePrefix(lang), id: entrySlug(product.id) },
      props: { product, lang },
    };
  });
}

const { product, lang } = Astro.props as { product: any; lang: Lang };
const { data } = product;
const { Content } = await render(product);
const t = useTranslations(lang);
---
<BaseLayout title={`${data.title} (${data.sku})`} description={data.summary} lang={lang}>
  <section class="hero" style="padding-bottom:1.5rem;">
    <div class="wrap">
      <a href={localizedPath(lang, '/')} style="font-size:0.9rem; color:var(--text-dim);">{t('product.back')}</a>
      <span class="eyebrow" style="display:block; margin-top:1rem;">{data.sku} · {t(`role.${data.role}` as any)}</span>
      <h1>{data.title}</h1>
      <p class="lead">{data.tagline}</p>
      <div class="cta">
        <a class="btn btn-primary" href={localizedPath(lang, '/docs/getting-started')}>{t('product.cta')}</a>
      </div>
    </div>
  </section>

  <section class="wrap">
    <div class="docs" style="grid-template-columns: 1fr 300px;">
      <article class="prose">
        <Content />
      </article>
      <aside>
        {data.specs.length > 0 && (
          <div class="card">
            <h3 style="margin-top:0;">{t('product.specs')}</h3>
            <table class="spec-table">
              <tbody>
                {data.specs.map((s: { label: string; value: string }) => (
                  <tr><td>{s.label}</td><td>{s.value}</td></tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </aside>
    </div>

    {data.features.length > 0 && (
      <div style="margin-top:3rem;">
        <h2 class="section-title">{t('product.highlights')}</h2>
        <p class="section-sub">&nbsp;</p>
        <div class="grid grid-2">
          {data.features.map((f: { title: string; body: string }) => (
            <div class="card">
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
