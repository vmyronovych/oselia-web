---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Page not found">
  <section class="hero">
    <div class="wrap" style="text-align:center;">
      <span class="eyebrow">404</span>
      <h1>This page went cold.</h1>
      <p class="lead" style="margin-inline:auto;">The page you're after doesn't exist.</p>
      <div class="cta" style="justify-content:center;">
        <a class="btn btn-primary" href={`${base}/`}>Back home</a>
        <a class="btn btn-ghost" href={`${base}/docs/getting-started`}>Getting Started</a>
      </div>
    </div>
  </section>
</BaseLayout>
