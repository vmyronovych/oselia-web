---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, defaultLang } from '../i18n/ui';
import { localizedPath } from '../i18n/utils';

// A 404 can be served for any path, including /uk/…; default to English chrome.
const lang = defaultLang;
const t = useTranslations(lang);
---
<BaseLayout title={t('404.title')} lang={lang}>
  <section class="hero">
    <div class="wrap" style="text-align:center;">
      <span class="eyebrow">{t('404.eyebrow')}</span>
      <h1>{t('404.title')}</h1>
      <p class="lead" style="margin-inline:auto;">{t('404.lead')}</p>
      <div class="cta" style="justify-content:center;">
        <a class="btn btn-primary" href={localizedPath(lang, '/')}>{t('404.home')}</a>
        <a class="btn btn-ghost" href={localizedPath(lang, '/docs/getting-started')}>{t('nav.gettingStarted')}</a>
      </div>
    </div>
  </section>
</BaseLayout>
