---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { type Lang } from '../i18n/ui';
import { entryLang, entrySlug, localizedPath } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  current: string; // locale-agnostic slug, e.g. 'getting-started'
  lang: Lang;
}
const { title, description, current, lang } = Astro.props;

const docs = (
  await getCollection('docs', ({ id, data }) => entryLang(id) === lang && !data.draft)
).sort((a, b) => a.data.order - b.data.order);

// Group by section, preserving first-seen order.
const sections: { name: string; items: typeof docs }[] = [];
for (const doc of docs) {
  let group = sections.find((s) => s.name === doc.data.section);
  if (!group) {
    group = { name: doc.data.section, items: [] };
    sections.push(group);
  }
  group.items.push(doc);
}
---
<BaseLayout title={title} description={description} lang={lang}>
  <div class="wrap">
    <div class="docs">
      <nav class="docs-sidebar" aria-label="Documentation">
        {sections.map((section) => (
          <div class="group">
            <div class="group-title">{section.name}</div>
            {section.items.map((doc) => {
              const slug = entrySlug(doc.id);
              return (
                <a
                  href={localizedPath(lang, `/docs/${slug}`)}
                  class={slug === current ? 'active' : ''}
                  aria-current={slug === current ? 'page' : undefined}
                >
                  {doc.data.title}
                </a>
              );
            })}
          </div>
        ))}
      </nav>
      <article class="prose">
        <h1>{title}</h1>
        <slot />
      </article>
    </div>
  </div>
</BaseLayout>
